<Window x:Class="ConstruxERP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ConstruxERP.Views"
        Title="ConstruxERP — İnşaat Malzemeleri Yöneticisi"
        Height="780" Width="1300"
        MinHeight="640" MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ContentBg}"
        FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <DockPanel>

                <!-- Brand / Logo -->
                <Border DockPanel.Dock="Top"
                        Padding="18,20,18,18"
                        BorderBrush="#1E293B"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="8" Background="#2563EB">
                            <TextBlock Text="C" FontSize="19" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ConstruxERP"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="ERP YÖNETİCİSİ"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="#475569"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- User card at bottom -->
                <Border DockPanel.Dock="Bottom"
                        Padding="16,14"
                        BorderBrush="#1E293B"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="50" Height="50" CornerRadius="17" Background="#2563EB">
                            <TextBlock Text="Hüseyin" FontSize="12" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Onbaşıoglu"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#E2E8F0"/>
                            <TextBlock Text="İnşaat Malzemeleri"
                                       FontSize="11" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav links -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,10,0,0">

                        <!-- MAIN -->
                        <TextBlock Text="ANA MENÜ"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="18,10,0,4"/>

                        <Button x:Name="BtnDashboard"
                                Style="{StaticResource NavButtonActive}"
                                Click="NavButton_Click" Tag="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Gösterge Paneli" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnInventory"
                                Style="{StaticResource NavButton}"
                                Click="NavButton_Click" Tag="Inventory">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Envanter" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnCustomers"
                                Style="{StaticResource NavButton}"
                                Click="NavButton_Click" Tag="Customers">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Müşteriler" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnSuppliers"
                                Style="{StaticResource NavButton}"
                                Click="NavButton_Click" Tag="Suppliers">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Tedarikçiler" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- FINANCE -->
                        <TextBlock Text="FİNANS"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="18,14,0,4"/>

                        <Button x:Name="BtnReports"
                                Style="{StaticResource NavButton}"
                                Click="NavButton_Click" Tag="Reports">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📈" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Raporlar &amp; Analiz" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- SYSTEM -->
                        <TextBlock Text="SİSTEM"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="18,14,0,4"/>

                        <Button x:Name="BtnBackup"
                                Style="{StaticResource NavButton}"
                                Click="NavButton_Click" Tag="Backup">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Yedekleme Yöneticisi" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="Özgün Yazılım 2026"
                                   FontSize="10" Foreground="#334155"
                                   Margin="18,16,0,8"/>
                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ═══════════════════ CONTENT AREA ═══════════════════ -->
        <ContentControl x:Name="MainContent"
                        Grid.Column="1"
                        Background="{StaticResource ContentBg}"/>

    </Grid>
</Window>