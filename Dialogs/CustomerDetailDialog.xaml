<Window x:Class="ConstruxERP.Dialogs.CustomerDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Müşteri Detayı"
        Width="860" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F8FAFC"
        FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Info cards -->
            <RowDefinition Height="*"/>      <!-- Tabs + lists -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0F172A" Padding="24,18">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Avatar -->
                    <Border Width="46" Height="46" CornerRadius="23"
                            Background="#2563EB">
                        <TextBlock x:Name="TxtInitials" Text=""
                                   FontSize="16" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtName"
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock x:Name="TxtPhone" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="  ·  " FontSize="12" Foreground="#334155"/>
                            <TextBlock x:Name="TxtEmail" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Edit button -->
                <Button x:Name="BtnEdit"
                        Content="✏ Düzenle"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource SecondaryButton}"
                        Height="34" Padding="14,0"
                        Background="#1E293B" BorderBrush="#334155" Foreground="#94A3B8"
                        Click="BtnEdit_Click"/>
            </Grid>
        </Border>

        <!-- ── Info Cards ───────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total purchases -->
                <StackPanel Grid.Column="0" Margin="4,0">
                    <TextBlock Text="TOPLAM ALIM" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtTotalPurchases"
                               Text="₺0,00" FontSize="18" FontWeight="Bold"
                               Foreground="#0F172A" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Total paid -->
                <StackPanel Grid.Column="1" Margin="4,0">
                    <TextBlock Text="TOPLAM ÖDENEN" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtTotalPaid"
                               Text="₺0,00" FontSize="18" FontWeight="Bold"
                               Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Outstanding debt -->
                <StackPanel Grid.Column="2" Margin="4,0">
                    <TextBlock Text="KALAN BORÇ" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtDebt"
                               Text="₺0,00" FontSize="18" FontWeight="Bold"
                               Foreground="#EF4444" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Transaction count -->
                <StackPanel Grid.Column="3" Margin="4,0">
                    <TextBlock Text="İŞLEM SAYISI" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtTxCount"
                               Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="#2563EB" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Tabs + Lists ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Purchase history -->
            <Border Grid.Column="0"
                    Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="16,12" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                        <TextBlock Text="🛒  Alım Geçmişi"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Column headers -->
                            <Border Background="#F8FAFC" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                <Grid Margin="14,0" Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="TARİH"   FontSize="10" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="ÜRÜN"    FontSize="10" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="ADET"    FontSize="10" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="TOPLAM"  FontSize="10" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="ÖDENEN"  FontSize="10" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="BORÇ"    FontSize="10" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ItemsControl x:Name="SalesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Border Background="{Binding RowBg}">
                                                <Grid Margin="14,0" MinHeight="48">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="88"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="72"/>
                                                        <ColumnDefinition Width="72"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding DateShort}"
                                                               FontSize="11" Foreground="#64748B"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ProductName}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#0F172A"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Note}"
                                                                   FontSize="10" Foreground="#94A3B8"
                                                                   Visibility="{Binding NoteVisibility}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding QtyDisplay}"
                                                               FontSize="12" Foreground="#374151"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding Total}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#0F172A"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding Paid}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#10B981"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="5"
                                                               Text="{Binding Debt}"
                                                               FontSize="12" FontWeight="Bold"
                                                               Foreground="{Binding DebtFg}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <Rectangle Height="1" Fill="#F1F5F9" Margin="14,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="TxtNoSales"
                                       Text="Henüz alım kaydı yok."
                                       FontSize="13" Foreground="#94A3B8"
                                       HorizontalAlignment="Center" Margin="0,24"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right column: Address + Payment history -->
            <StackPanel Grid.Column="2">

                <!-- Address card -->
                <Border Background="White" CornerRadius="10"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <Border Padding="14,11" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                            <TextBlock Text="📍  Adres Bilgileri"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        </Border>
                        <StackPanel Margin="14,10,14,14">
                            <TextBlock Text="MÜŞTERİ ADRESİ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtAddress"
                                       Text="—" FontSize="12" Foreground="#374151"
                                       TextWrapping="Wrap"/>

                            <Border Height="1" Background="#F1F5F9" Margin="0,10"/>

                            <TextBlock Text="FATURA ADRESİ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtBillingAddress"
                                       Text="—" FontSize="12" Foreground="#374151"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="TxtBillingNote"
                                       Text="(Müşteri adresi ile aynı)"
                                       FontSize="11" Foreground="#94A3B8"
                                       Visibility="Collapsed" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Payment history -->
                <Border Background="White" CornerRadius="10"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="14,11" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                            <TextBlock Text="💳  Ödeme Geçmişi"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        </Border>

                        <ScrollViewer Grid.Row="1" MaxHeight="220"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <ItemsControl x:Name="PaymentList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Grid Margin="14,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DateShort}"
                                                                   FontSize="11" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding Notes}"
                                                                   FontSize="11" Foreground="#94A3B8"
                                                                   Visibility="{Binding NotesVisibility}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding AmountDisplay}"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="#10B981"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                                <Rectangle Height="1" Fill="#F1F5F9" Margin="14,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock x:Name="TxtNoPayments"
                                           Text="Henüz ödeme kaydı yok."
                                           FontSize="12" Foreground="#94A3B8"
                                           HorizontalAlignment="Center" Margin="0,16"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </StackPanel>
        </Grid>

        <!-- ── Footer ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="3" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Background="White" Padding="20,12" Margin="0,16,0,0">
            <Grid>
                <TextBlock x:Name="TxtMemberSince"
                           FontSize="12" Foreground="#94A3B8"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Kapat"
                            Style="{StaticResource SecondaryButton}"
                            IsCancel="True" Height="36" Padding="16,0"
                            Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
