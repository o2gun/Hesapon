<Window x:Class="ConstruxERP.Dialogs.RecordPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ödeme Kaydı" Height="350" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TxtTitle" Text="Tahsilat İşlemi" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Müşteriden alınan ödeme tutarını ve notunu giriniz." FontSize="12" Foreground="#64748B"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#475569">
                <Run Text="Ödeme Tutarı (TL)"/>
                <Run Text=" (İade için başına '-' koyun)" FontSize="10" Foreground="#94A3B8"/>
            </TextBlock>
            <TextBox x:Name="TxtAmount" Padding="10" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Background="White" BorderBrush="#E2E8F0"/>

            <TextBlock Text="Açıklama / Not" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#475569"/>
            <TextBox x:Name="TxtNotes" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                     Padding="10" VerticalContentAlignment="Top" Background="White" BorderBrush="#E2E8F0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnCancel" Content="İptal" Width="80" Height="35" 
                    Margin="0,0,10,0" Background="Transparent" BorderBrush="#E2E8F0" 
                    Click="BtnCancel_Click"/>

            <Button x:Name="BtnSave" Content="Kaydet" Width="120" Height="35" 
                    Background="#2563EB" Foreground="White" FontWeight="Bold"
                    Click="BtnSave_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>