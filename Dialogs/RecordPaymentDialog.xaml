<Window x:Class="ConstruxERP.Dialogs.RecordPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record Debt Payment"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="{StaticResource AppFont}">

    <StackPanel>
        <!-- Header -->
        <Border Background="#DC2626" Padding="24,18">
            <StackPanel>
                <TextBlock Text="Borç Ödeme Kaydı"
                           FontSize="17" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="TxtCustomerName" Text=""
                           FontSize="12" Foreground="#FECACA" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Info + Form -->
        <StackPanel Margin="24,18,24,0">

            <!-- Debt summary -->
            <Border Background="#FEF2F2" CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
                <Grid>
                    <TextBlock Text="Ödenmemiş Bakiye"
                               FontSize="12" FontWeight="SemiBold" Foreground="#991B1B"/>
                    <TextBlock x:Name="TxtOutstanding" Text="₺0.00"
                               HorizontalAlignment="Right"
                               FontSize="15" FontWeight="Bold" Foreground="#DC2626"/>
                </Grid>
            </Border>

            <TextBlock Text="Ödeme Tutarı (₺) *" FontSize="12" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtAmount" Style="{StaticResource FormTextBox}"
                     Margin="0,0,0,14"/>

            <TextBlock Text="Not (opsiyonel)" FontSize="12" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtNotes" Height="56" Padding="10,8"
                     FontSize="13" BorderBrush="#D1D5DB" BorderThickness="1"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,0,0,6">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="White"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,8"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock x:Name="TxtError" Foreground="#DC2626" FontSize="12"
                       Margin="0,4,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Footer -->
        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,16" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="İptal" Style="{StaticResource SecondaryButton}"
                        IsCancel="True" Height="38" Padding="18,0" Click="Button_Click"/>
                <Button Content="✓ Ödeme Kayıt" Style="{StaticResource PrimaryButton}"
                        Height="38" Padding="18,0" Margin="10,0,0,0"
                        Background="#DC2626"
                        Click="BtnRecord_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
