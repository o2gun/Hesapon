<Window x:Class="ConstruxERP.Dialogs.AddEditCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Müşteri"
        Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="{StaticResource AppFont}">

    <StackPanel>
        <!-- Header -->
        <Border Background="#0F172A" Padding="24,18">
            <TextBlock x:Name="TxtTitle" Text="Yeni Müşteri Ekle"
                       FontSize="17" FontWeight="Bold" Foreground="White"/>
        </Border>

        <StackPanel Margin="24,18,24,0">

            <!-- Ad -->
            <TextBlock Text="Müşteri Adı *" FontSize="12" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtName" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"/>

            <!-- Telefon + Email -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Telefon" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtPhone" Style="{StaticResource FormTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="E-Posta" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtEmail" Style="{StaticResource FormTextBox}"/>
                </StackPanel>
            </Grid>

            <!-- Adres -->
            <TextBlock Text="Müşteri Adresi (Teslimat / İkamet)"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtAddress"
                     Height="60" Padding="10,8" FontSize="13"
                     BorderBrush="#D1D5DB" BorderThickness="1"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,14">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="White"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,8"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Fatura Adresi -->
            <Grid Margin="0,0,0,5">
                <TextBlock Text="Fatura Adresi"
                           FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                <TextBlock Text="(boş bırakılırsa müşteri adresi kullanılır)"
                           FontSize="11" Foreground="#94A3B8"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <TextBox x:Name="TxtBillingAddress"
                     Height="60" Padding="10,8" FontSize="13"
                     BorderBrush="#D1D5DB" BorderThickness="1"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,6">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="White"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,8"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock x:Name="TxtError" Foreground="#DC2626" FontSize="12"
                       Margin="0,4,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Footer -->
        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,16" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="İptal" Style="{StaticResource SecondaryButton}"
                        IsCancel="True" Height="38" Padding="18,0"/>
                <Button Content="✓ Kaydet" Style="{StaticResource PrimaryButton}"
                        Height="38" Padding="18,0" Margin="10,0,0,0"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
