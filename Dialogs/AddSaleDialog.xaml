<Window x:Class="ConstruxERP.Dialogs.AddSaleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yeni Satış"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="{StaticResource AppFont}">

    <StackPanel>
        <!-- Header -->
        <Border Background="#2563EB" Padding="24,18">
            <StackPanel>
                <TextBlock Text="+ Yeni Satış İşlemi"
                           FontSize="17" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Satış bilgilerini doldurun"
                           FontSize="12" Foreground="#BFDBFE" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Margin="24,18,24,0">

            <!-- Müşteri -->
            <TextBlock Text="Müşteri *" FontSize="12" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbCustomer" Style="{StaticResource ModernComboBox}"
                      Margin="0,0,0,14" IsEditable="True"
                      SelectionChanged="CmbCustomer_SelectionChanged"/>

            <!-- Ürün -->
            <TextBlock Text="Ürün *" FontSize="12" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbProduct" Style="{StaticResource ModernComboBox}"
                      Margin="0,0,0,14" IsEditable="True"
                      SelectionChanged="CmbProduct_SelectionChanged"/>

            <!-- Adet + Birim Fiyat -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Miktar *" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtQty" Style="{StaticResource FormTextBox}"
                             Text="1" TextChanged="RecalcTotal"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Birim Fiyat (₺) *" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtUnitPrice" Style="{StaticResource FormTextBox}"
                             TextChanged="RecalcTotal"/>
                </StackPanel>
            </Grid>

            <!-- Toplam (otomatik) -->
            <Border Background="#EFF6FF" CornerRadius="6" Padding="14,10" Margin="0,0,0,14">
                <Grid>
                    <TextBlock Text="Toplam Tutar (otomatik hesaplanır)"
                               FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                    <TextBlock x:Name="TxtTotal" Text="₺0,00"
                               HorizontalAlignment="Right"
                               FontSize="15" FontWeight="Bold" Foreground="#1D4ED8"/>
                </Grid>
            </Border>

            <!-- Ödenen + Ödeme Türü -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Ödenen Tutar (₺)" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtPaid" Style="{StaticResource FormTextBox}"
                             Text="0" TextChanged="RecalcTotal"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ödeme Türü" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbPaymentType" Style="{StaticResource ModernComboBox}"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Nakit"/>
                        <ComboBoxItem Content="Kredi"/>
                        <ComboBoxItem Content="Kısmi"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Kalan borç -->
            <Border Background="#FEF2F2" CornerRadius="6" Padding="14,10" Margin="0,0,0,14">
                <Grid>
                    <TextBlock Text="Kalan Borç"
                               FontSize="12" FontWeight="SemiBold" Foreground="#991B1B"/>
                    <TextBlock x:Name="TxtDebt" Text="₺0,00"
                               HorizontalAlignment="Right"
                               FontSize="15" FontWeight="Bold" Foreground="#DC2626"/>
                </Grid>
            </Border>

            <!-- Not alanı -->
            <Grid Margin="0,0,0,5">
                <TextBlock Text="Not / Açıklama"
                           FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                <TextBlock Text="(opsiyonel)"
                           FontSize="10" Foreground="#94A3B8"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <TextBox x:Name="TxtNote"
                     Height="56" Padding="10,8" FontSize="13"
                     BorderBrush="#D1D5DB" BorderThickness="1"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,6">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="White"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,8"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock x:Name="TxtError" Foreground="#DC2626" FontSize="12"
                       Margin="0,4,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Footer -->
        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,16" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="İptal" Style="{StaticResource SecondaryButton}"
                        IsCancel="True" Height="38" Padding="18,0"/>
                <Button Content="✓ Satışı Kaydet" Style="{StaticResource PrimaryButton}"
                        Height="38" Padding="18,0" Margin="10,0,0,0"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
