<UserControl x:Class="ConstruxERP.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBg}"
             Loaded="UserControl_Loaded">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,24" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Finansal Raporlar" Style="{StaticResource PageTitle}" FontSize="22"/>
                    <TextBlock Text="İşletmenizin nakit akışı ve satış analizleri" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Dönem:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,10,0"/>

                    <Button Content="Bugün" Tag="Today" Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,5,5" Click="BtnQuickFilter_Click"/>
                    <Button Content="Bu Ay" Tag="ThisMonth" Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,5,5" Click="BtnQuickFilter_Click"/>
                    <Button Content="3 Ay" Tag="3Months" Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,5,5" Click="BtnQuickFilter_Click"/>
                    <Button Content="12 Ay" Tag="12Months" Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,15,5" Click="BtnQuickFilter_Click"/>

                    <DatePicker x:Name="DpStart" Width="115" SelectedDateChanged="DpDate_SelectedDateChanged" Margin="0,0,5,5"/>
                    <TextBlock Text=" - " VerticalAlignment="Center" Margin="0,0,5,5"/>
                    <DatePicker x:Name="DpEnd" Width="115" SelectedDateChanged="DpDate_SelectedDateChanged" Margin="0,0,0,5"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="TAHSİLAT (GİREN NAKİT)" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtTotalCollections" Text="₺0,00" FontSize="22" FontWeight="Bold" Foreground="#10B981" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="ÖDEMELER (ÇIKAN NAKİT)" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtTotalPayments" Text="₺0,00" FontSize="22" FontWeight="Bold" Foreground="#EF4444" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="#F8FAFC" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="NET NAKİT AKIŞI" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtNetCashFlow" Text="₺0,00" FontSize="22" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="TOPLAM SATIŞ HACMİ" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtTotalSales" Text="₺0,00" FontSize="22" FontWeight="Bold" Foreground="#3B82F6" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Padding="20,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Background="#F8FAFC" CornerRadius="12,12,0,0">
                        <TextBlock Text="🏆 En Çok Satan Ürünler (Seçili Dönem)" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" Margin="20">
                        <ItemsControl x:Name="ListTopProducts">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ProductName}" FontSize="14" FontWeight="Medium" Foreground="#1E293B" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalQty, StringFormat={}{0} Adet/Birim}" FontSize="13" Foreground="#64748B" Margin="15,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TotalRevenue, StringFormat=C, ConverterCulture=tr-TR}" FontSize="14" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="💡 Raporlama Hakkında" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,15"/>
                    <TextBlock Text="• Tahsilat (Giren Nakit): Müşterilerinizden peşin veya sonradan aldığınız tüm ödemelerin toplamıdır." 
                               TextWrapping="Wrap" Foreground="#475569" Margin="0,0,0,10" LineHeight="20"/>
                    <TextBlock Text="• Ödemeler (Çıkan Nakit): Tedarikçilerinize yaptığınız peşin veya sonradan ödemelerin toplamıdır." 
                               TextWrapping="Wrap" Foreground="#475569" Margin="0,0,0,10" LineHeight="20"/>
                    <TextBlock Text="• Toplam Satış Hacmi: Satılan ürünlerin toplam parasal değeridir. Kasanıza girmemiş (borçlu) satışlar da bu hacme dahildir." 
                               TextWrapping="Wrap" Foreground="#475569" LineHeight="20"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>