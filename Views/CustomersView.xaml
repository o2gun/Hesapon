<UserControl x:Class="ConstruxERP.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBg}"
             Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header Bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Başlık (Cursor="" kaldırıldı) -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Müşteriler"
                               Style="{StaticResource PageTitle}" FontSize="20"/>
                    <TextBlock Text="Müşterileri yönetin ve açık borçları takip edin"
                               FontSize="12" Foreground="{StaticResource TextSecondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="1" x:Name="TxtSearch"
                         Style="{StaticResource SearchBox}"
                         TextChanged="TxtSearch_TextChanged"/>

                <Button Grid.Column="3" Content="+ Müşteri Ekle"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnAddCustomer_Click" Height="36" Padding="14,0"/>
            </Grid>
        </Border>

        <!-- ── Customer Table ─────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Column Headers
                         Sütun genişlikleri:
                         Col 0 (İsim)    : 220  — avatar + metin için biraz geniş
                         Col 1 (Telefon) : 130
                         Col 2 (Toplam)  : 130
                         Col 3 (Tahsil)  : 120
                         Col 4 (Borç)    : 130
                         Col 5 (İşlemler): *    — geri kalan tüm alanı doldurur
                    -->
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <Grid Margin="28,0" Height="38">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MÜŞTERİ ADI"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="#64748B" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="TELEFON"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="#64748B" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="TOPLAM ALIŞVERİŞ"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="#64748B" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="TAHSİL EDİLEN"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="#64748B" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="KALAN BORÇ"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="#64748B" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="İŞLEMLER"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="#64748B" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Data Rows -->
                    <ItemsControl x:Name="CustomerList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Background="{Binding RowBg}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Margin="28,0" Height="60">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Col 0: Avatar + İsim -->
                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Width="34" Height="34"
                                                        CornerRadius="17"
                                                        Background="{Binding AvatarBg}">
                                                    <TextBlock Text="{Binding Initials}"
                                                               FontSize="12" FontWeight="Bold"
                                                               Foreground="{Binding AvatarFg}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#0F172A"
                                                           VerticalAlignment="Center"
                                                           Margin="9,0,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="150"/>
                                            </StackPanel>

                                            <!-- Col 1: Telefon -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Phone}"
                                                       FontSize="13" Foreground="#374151"
                                                       VerticalAlignment="Center"/>

                                            <!-- Col 2: Toplam Alışveriş -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TotalPurchasesDisplay}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#0F172A"
                                                       VerticalAlignment="Center"/>

                                            <!-- Col 3: Tahsil Edilen -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding TotalPaidDisplay}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Green}"
                                                       VerticalAlignment="Center"/>

                                            <!-- Col 4: Kalan Borç chip -->
                                            <Border Grid.Column="4"
                                                    Background="{Binding DebtBg}"
                                                    CornerRadius="4" Padding="8,3"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding DebtDisplay}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="{Binding DebtFg}"/>
                                            </Border>

                                            <!-- Col 5: Butonlar (sol hizalı, * sütun içinde) -->
                                            <StackPanel Grid.Column="5"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="Görüntüle"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Height="28" Padding="12,0"
                                                        Tag="{Binding Id}"
                                                        Click="BtnView_Click"/>
                                            </StackPanel>

                                        </Grid>
                                    </Border>
                                    <Rectangle Height="1" Fill="#F1F5F9" Margin="28,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtEmpty"
                               Text="Kayıtlı müşteri bulunamadı."
                               FontSize="14" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,48"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── Footer / Pagination ────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="28,12">
            <TextBlock x:Name="TxtPagingInfo"
                       FontSize="13" Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
