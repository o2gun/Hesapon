<UserControl x:Class="ConstruxERP.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC" Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Üst Bar (Başlık + Arama + Filtreler) -->
            <RowDefinition Height="*"/>
            <!-- Ana İçerik (Liste veya Detay) -->
            <RowDefinition Height="Auto"/>
            <!-- Sayfalama (Pagination) -->
        </Grid.RowDefinitions>

        <!-- ÜST BAR (Başlık ve Arama/Filtre) -->
        <Border Grid.Row="0" Background="White" Padding="15" Margin="0,0,0,10" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Tedarikçiler" FontSize="24" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>

                <!-- Arama ve Gelişmiş Filtreler -->
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBox x:Name="TxtSearch" Width="200" Margin="0,0,10,5" Style="{StaticResource SearchBox}" TextChanged="FilterChanged"/>

                    <!-- Modern Switch -->
                    <StackPanel Orientation="Vertical" Margin="0,0,15,5" VerticalAlignment="Center">
                        <TextBlock Text="Gelişmiş Filtreler" FontSize="10" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                        <ToggleButton x:Name="TglAdvancedFilters" IsChecked="False" Click="FilterChanged" HorizontalAlignment="Center">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background" Value="#CBD5E1"/>
                                    <Setter Property="Width" Value="36"/>
                                    <Setter Property="Height" Value="20"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="SwitchBg" Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <Ellipse x:Name="Knob" Fill="White" Width="16" Height="16" HorizontalAlignment="Left" Margin="2,0,2,0" VerticalAlignment="Center">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Direction="270"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="SwitchBg" Property="Background" Value="#10B981"/>
                                                        <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </StackPanel>

                    <!-- Alt Filtreler (Switch kapalıyken IsEnabled=False) -->
                    <StackPanel x:Name="PnlAdvancedFilters" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkSearchName" Content="Firma" IsChecked="True" Margin="0,0,5,5" IsEnabled="{Binding IsChecked, ElementName=TglAdvancedFilters}" Click="FilterChanged"/>
                        <CheckBox x:Name="ChkSearchContact" Content="Yetkili" IsChecked="True" Margin="0,0,15,5" IsEnabled="{Binding IsChecked, ElementName=TglAdvancedFilters}" Click="FilterChanged"/>

                        <TextBlock Text="Min Borç:" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="#64748B" FontSize="12"/>
                        <TextBox x:Name="TxtMinDebt" Width="80" Text="0" Padding="4" Margin="0,0,0,5" IsEnabled="{Binding IsChecked, ElementName=TglAdvancedFilters}" TextChanged="FilterChanged"/>
                    </StackPanel>
                </WrapPanel>

                <Button Grid.Column="2" Content="+ Yeni Tedarikçi" Background="#2563EB" Foreground="White" Padding="15,5" BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click"/>
            </Grid>
        </Border>

        <!-- LİSTE EKRANI (DataGrid) -->
        <DataGrid x:Name="GridList" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Single" SelectionUnit="FullRow" HeadersVisibility="Column" 
                  Background="White" BorderThickness="0" RowHeight="40" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Firma Adı" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Yetkili" Binding="{Binding ContactName}" Width="150"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Toplam Alım" Binding="{Binding TotalPurchased, StringFormat=C}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Foreground" Value="#1E293B"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Ödenen" Binding="{Binding TotalPaid, StringFormat=C}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Foreground" Value="#10B981"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Kalan Borcumuz" Binding="{Binding TotalDebt, StringFormat=C}" Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#EF4444"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Görüntüle (Detay), Düzenle, Sil Butonları -->
                <DataGridTemplateColumn Header="İşlemler" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Görüntüle (Aynı Müşterilerdeki Gibi) -->
                                <Button Content="Görüntüle" Background="#F1F5F9" Foreground="#475569" BorderThickness="0" Padding="8,2" Margin="0,0,5,0" Cursor="Hand" Tag="{Binding Id}" Click="BtnShowDetail_Click"/>
                                <!-- Düzenle -->
                                <Button Content="✎" ToolTip="Düzenle" Background="Transparent" Foreground="#2563EB" BorderThickness="0" Margin="0,0,5,0" Cursor="Hand" Tag="{Binding Id}" Click="BtnEdit_Click"/>
                                <!-- Sil -->
                                <Button Content="🗑" ToolTip="Sil" Background="Transparent" Foreground="#EF4444" BorderThickness="0" Cursor="Hand" Tag="{Binding Id}" Click="BtnDelete_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- DETAY EKRANI (Aynı Müşterilerdeki Gibi GridList Gizlenip Bu Açılacak) -->
        <Border x:Name="GridDetail" Grid.Row="1" Visibility="Collapsed" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="-2" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Üst Bar (İsim + Butonlar) -->
                    <RowDefinition Height="*"/>
                    <!-- Alımlar ve Ödemeler Yan Yana -->
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="TxtDetailTitle" FontSize="20" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Yeni Alım" Background="#2563EB" Foreground="White" Padding="15,5" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Click="BtnAddPurchase_Click"/>
                        <Button Content="+ Ödeme Yap" Background="#10B981" Foreground="White" Padding="15,5" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0" Click="BtnMakePayment_Click"/>
                        <Button Content="Geri Dön" Background="#F1F5F9" Foreground="#475569" Padding="15,5" BorderThickness="0" Cursor="Hand" Click="BtnCloseDetail_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Yan Yana Alım Geçmişi ve Ödeme Geçmişi -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ALIM GEÇMİŞİ -->
                    <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Background="#F8FAFC" Padding="10" CornerRadius="6,6,0,0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <TextBlock Text="ALIM GEÇMİŞİ" FontWeight="Bold" Foreground="#475569" FontSize="12"/>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Grid Margin="12,8" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="TARİH" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="1" Text="ÜRÜN" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="2" Text="TUTAR" FontSize="10" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="BORÇ" FontSize="10" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="İŞLEM" FontSize="10" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <ItemsControl x:Name="DetailPurchaseList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Grid Margin="12,6" MinHeight="30">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="50"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding DateShort}" FontSize="11" Foreground="#64748B" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ProductName}" FontSize="11" Foreground="#374151" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding TotalDisplay}" FontSize="12" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding DebtDisplay}" FontSize="12" FontWeight="Bold" Foreground="#DC2626" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                            <Button Content="✎" ToolTip="Düzenle" Background="Transparent" BorderThickness="0" Foreground="#2563EB" Tag="{Binding PurchaseId}" Click="BtnEditPurchase_Click" Cursor="Hand" Margin="0,0,5,0"/>
                                                            <Button Content="🗑" ToolTip="Sil" Background="Transparent" BorderThickness="0" Foreground="#EF4444" Tag="{Binding PurchaseId}" Click="BtnDeletePurchase_Click" Cursor="Hand"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Rectangle Height="1" Fill="#F1F5F9" Margin="12,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- ÖDEME GEÇMİŞİ -->
                    <Border Grid.Column="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Background="#F8FAFC" Padding="10" CornerRadius="6,6,0,0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <TextBlock Text="ÖDEME GEÇMİŞİ" FontWeight="Bold" Foreground="#475569" FontSize="12"/>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Grid Margin="12,8" Height="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="TARİH" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="1" Text="NOTLAR" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="2" Text="TUTAR" FontSize="10" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="İŞLEM" FontSize="10" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <ItemsControl x:Name="DetailPaymentList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Grid Margin="12,6" MinHeight="30">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="50"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding DateShort}" FontSize="11" Foreground="#64748B" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Notes}" FontSize="11" Foreground="#374151" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding AmountDisplay}" FontSize="12" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                            <Button Content="✎" ToolTip="Düzenle" Background="Transparent" BorderThickness="0" Foreground="#2563EB" Tag="{Binding PaymentId}" Click="BtnEditPayment_Click" Cursor="Hand" Margin="0,0,5,0"/>
                                                            <Button Content="🗑" ToolTip="Sil" Background="Transparent" BorderThickness="0" Foreground="#EF4444" Tag="{Binding PaymentId}" Click="BtnDeletePayment_Click" Cursor="Hand"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Rectangle Height="1" Fill="#F1F5F9" Margin="12,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- SAYFALAMA PANELI (Ana GridList görünürken aktif olacak) -->
        <StackPanel x:Name="PnlPagination" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="Önceki" Padding="15,5" Margin="0,0,10,0" Background="#F1F5F9" BorderThickness="0" Click="BtnPrev_Click"/>
            <TextBlock x:Name="TxtPageInfo" Text="Sayfa 1 / 1" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B" FontWeight="SemiBold"/>
            <Button Content="Sonraki" Padding="15,5" Background="#F1F5F9" BorderThickness="0" Click="BtnNext_Click"/>
        </StackPanel>
    </Grid>
</UserControl>