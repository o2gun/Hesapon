<UserControl x:Class="ConstruxERP.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBg}" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="28,16">
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="+ Tedarikçi Ekle" Style="{StaticResource PrimaryButton}" 
            Height="36" Padding="14,0" Click="BtnAddSupplier_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="28,20" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="GridSuppliers" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      Background="Transparent" BorderThickness="0" RowHeight="45" ColumnHeaderHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Firma Adı" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="150"/>
                    <DataGridTextColumn Header="Kayıt Tarihi" Binding="{Binding CreatedAt}" Width="150"/>
                    <DataGridTextColumn Header="Toplam Borcumuz" Binding="{Binding TotalDebt, StringFormat={}{0:N2} ₺}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>