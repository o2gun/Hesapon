<UserControl x:Class="ConstruxERP.Views.DebtReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBg}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="28,16">
            <TextBlock Text="Borç Raporları" Style="{StaticResource PageTitle}" FontSize="20"/>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="28,20,28,28">
            <StackPanel>
                <Border Style="{StaticResource Card}" Padding="0">
                    <StackPanel>
                        <Border Padding="18,14" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="Borcu Olan Tüm Müşteriler"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="TxtTotal" Text="Toplam: ₺0,00"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource Red}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Column headers -->
                        <Border Background="#F8FAFC" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                            <Grid Margin="20,0" Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="MÜŞTERİ" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                                <TextBlock Grid.Column="1" Text="TELEFON" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                                <TextBlock Grid.Column="2" Text="KALAN BORÇ" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            </Grid>
                        </Border>

                        <ItemsControl x:Name="DebtList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid Margin="20,0" Height="52">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Phone}"
                                                       FontSize="13" Foreground="#374151"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding DebtDisplay}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#DC2626" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#F1F5F9" Margin="20,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtNone"
                                   Text="✅ Borç bulunmuyor."
                                   FontSize="13" Foreground="{StaticResource Green}"
                                   Margin="20,12" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>