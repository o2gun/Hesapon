<UserControl x:Class="ConstruxERP.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBg}" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Ürün Yönetimi" Style="{StaticResource PageTitle}" FontSize="20"/>
                    <TextBlock x:Name="TxtProductCount" Text="0 Ürün" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtSearch" Style="{StaticResource SearchBox}" Width="250" Margin="0,0,15,0" TextChanged="TxtSearch_TextChanged"/>
                    <Button Content="+ Ürün Ekle" Style="{StaticResource PrimaryButton}" Click="BtnAddProduct_Click" Height="36" Padding="14,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="GridList" Grid.Row="1" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White">
                <ScrollViewer>
                    <StackPanel>
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                            <Grid Margin="28,0" Height="38">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="105"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ÜRÜN ADI" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="KATEGORİ" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="ALIŞ FİYATI" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="SATIŞ FİYATI" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="TOPLAM STOK" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="İŞLEMLER" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                        <ItemsControl x:Name="ProductList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid Margin="28,0" MinHeight="50">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="105"/>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding PurchasePriceDisplay}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding SalePriceDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="#2563EB" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding StockDisplay}" FontSize="14" FontWeight="Bold" Foreground="{Binding StockColor}" VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Content="Görüntüle" Style="{StaticResource SecondaryButton}" Tag="{Binding Id}" Click="BtnViewDetail_Click" Margin="0,0,10,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#F1F5F9" Margin="28,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid x:Name="GridDetail" Grid.Row="1" Visibility="Collapsed" Background="#F8FAFC">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="#0F172A" Padding="24,18">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="← Geri Dön" Style="{StaticResource SecondaryButton}" Background="#1E293B" Foreground="White" BorderBrush="#334155" Margin="0,0,15,0" Click="BtnBackToList_Click"/>
                        <TextBlock x:Name="TxtDetailProductName" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="20" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Padding="14,10" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <TextBlock Text="📦 Alım Geçmişi (Düzenlenebilir)" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </Border>
                    <ScrollViewer Grid.Row="1">
                        <StackPanel>
                            <Grid Margin="14,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TARİH" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="1" Text="TEDARİKÇİ" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="2" Text="MİKTAR" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="3" Text="BİRİM FİYAT" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="4" Text="TOPLAM" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="5" Text="ÖDENEN" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="6" Text="KALAN BORÇ" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="7" Text="İŞLEM" FontSize="10" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                            </Grid>

                            <ItemsControl x:Name="PurchaseList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="14,8" MinHeight="30">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding PurchaseDate}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SupplierName}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Qty}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding UnitPrice, StringFormat={}{0:N2} ₺}" FontSize="12" Foreground="#2563EB" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="4" Text="{Binding TotalPrice, StringFormat={}{0:N2} ₺}" FontSize="12" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="5" Text="{Binding AmountPaid, StringFormat={}{0:N2} ₺}" FontSize="12" Foreground="#059669" FontWeight="Medium" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="6" Text="{Binding RemainingDebt, StringFormat={}{0:N2} ₺}" FontSize="12" Foreground="#DC2626" FontWeight="Bold" VerticalAlignment="Center"/>

                                            <Button Grid.Column="7" Content="Düzenle" Style="{StaticResource SecondaryButton}" Tag="{Binding Id}" Click="BtnEditPurchase_Click" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>