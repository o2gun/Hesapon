<UserControl x:Class="ConstruxERP.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBg}"
             Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Ürün Yönetimi" Style="{StaticResource PageTitle}" FontSize="20"/>
                        <Border Background="#F1F5F9" CornerRadius="14" Padding="10,4"
                                Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtProductCount"
                                       Text="0 Ürün" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <TextBox Grid.Column="1" x:Name="TxtSearch" Style="{StaticResource SearchBox}"
                         TextChanged="TxtSearch_TextChanged"/>
                <Button Grid.Column="3" Content="+ Ürün Ekle"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnAddProduct_Click" Height="36" Padding="14,0"/>
            </Grid>
        </Border>

        <!-- Product Table -->
        <Border Grid.Row="1" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Column Headers -->
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <Grid Margin="28,0" Height="38">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="105"/>
                                <ColumnDefinition Width="95"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ÜRÜN ADI"   Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="KATEGORİ"   Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="2" Text="BİRİM"      Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="3" Text="ALIŞ FİYATI" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="4" Text="SATIŞ FİYATI" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="5" Text="STOK"       Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="6" Text="MİN."       Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="7" Text="TEDARİKÇİ"  Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                            <TextBlock Grid.Column="8" Text="DÜZENLE"    Style="{StaticResource SectionLabel}" VerticalAlignment="Center" Margin="0"/>
                        </Grid>
                    </Border>

                    <!-- Data rows -->
                    <ItemsControl x:Name="ProductList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Red left-stripe for low stock -->
                                    <Grid>
                                        <Border Width="4" HorizontalAlignment="Left"
                                                Background="{Binding StripColor}"
                                                CornerRadius="0,2,2,0"/>
                                        <Grid Margin="28,0" MinHeight="64">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="105"/>
                                                <ColumnDefinition Width="95"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,8">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#0F172A" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Sku}" FontSize="11"
                                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Category}"
                                                       FontSize="13" Foreground="#374151" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Unit}"
                                                       FontSize="13" Foreground="#374151" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding PurchasePriceDisplay}"
                                                       FontSize="13" Foreground="#374151" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding SalePriceDisplay}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#2563EB" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="{Binding StockQty}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="{Binding StockColor}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="{Binding MinStock}"
                                                       FontSize="13" Foreground="{StaticResource TextMuted}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="7" Text="{Binding SupplierName}"
                                                       FontSize="13" Foreground="#374151"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="8" Content="Düzenle"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="28" Padding="10,0"
                                                    VerticalAlignment="Center"
                                                    Tag="{Binding Id}"
                                                    Click="BtnEdit_Click"/>
                                        </Grid>
                                    </Grid>
                                    <Rectangle Height="1" Fill="#F1F5F9" Margin="28,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtEmpty"
                               Text="Ürün bulunamadı. Başlamak için '+ Ürün Ekle'ye tıklayın."
                               FontSize="14" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,48"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Pagination -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="28,12">
            <Grid>
                <TextBlock x:Name="TxtPagingInfo"
                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="← Önceki" Style="{StaticResource SecondaryButton}"
                            Height="32" Padding="12,0" Click="BtnPrev_Click"
                            x:Name="BtnPrev" IsEnabled="False"/>
                    <TextBlock x:Name="TxtPageNum" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBlue}"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <Button Content="Sonraki →" Style="{StaticResource SecondaryButton}"
                            Height="32" Padding="12,0" Click="BtnNext_Click"
                            x:Name="BtnNext"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>