<UserControl x:Class="ConstruxERP.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBg}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="28,16">
            <Grid>
                <TextBlock Text="Yedekleme Yöneticisi" Style="{StaticResource PageTitle}" FontSize="20"/>
                <Button Content="💾 Yedekleme Oluştur"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right"
                        Height="38" Padding="16,0"
                        Click="BtnCreateBackup_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="28,20,28,28">
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <Border Padding="18,14" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                        <TextBlock Text="Available Backup Files"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </Border>

                    <ItemsControl x:Name="BackupList" Margin="18,8,18,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid Margin="0,8" Height="44">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#0F172A"/>
                                            <TextBlock Text="{Binding FileSize}"
                                                       FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Bu kayıt'a dön"
                                                Style="{StaticResource SecondaryButton}"
                                                Height="30" Padding="12,0"
                                                Tag="{Binding FullPath}"
                                                Click="BtnRestore_Click"/>
                                        <Button Grid.Column="3" Content="🗑"
                                                Style="{StaticResource SecondaryButton}"
                                                Height="30" Width="30" Padding="0"
                                                Tag="{Binding FullPath}"
                                                Click="BtnDeleteBackup_Click"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="#F1F5F9"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtNone"
                               Text="Yedekleme dosyası bulunamadı. Yeni bir yedekleme dosyası oluşturmak için 'Şimdi Yedekleme Oluştur' seçeneğine tıklayın.."
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               Margin="18,0,18,16" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
