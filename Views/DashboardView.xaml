<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="ConstruxERP.Views.DashboardView"
             Background="{StaticResource ContentBg}"
             Loaded="UserControl_Loaded">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Gösterge Paneli" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="İşletmenizin genel durumu ve özet veriler" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Dönem:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,10,0"/>

                <Button Content="1 Ay" Tag="1" Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,5,0" Click="BtnQuickFilter_Click"/>
                <Button Content="3 Ay" Tag="3" Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,5,0" Click="BtnQuickFilter_Click"/>
                <Button Content="6 Ay" Tag="6" Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,5,0" Click="BtnQuickFilter_Click"/>
                <Button Content="12 Ay" Tag="12" Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,15,0" Click="BtnQuickFilter_Click"/>

                <Border CornerRadius="8" BorderBrush="LightGray" BorderThickness="1" Padding="2" Background="White">
                    <DatePicker x:Name="DpStart" Language="tr-TR" Width="110" SelectedDateChanged="DpDate_SelectedDateChanged" BorderThickness="0" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text=" - " VerticalAlignment="Center" Margin="5,0"/>

                <Border CornerRadius="8" BorderBrush="LightGray" BorderThickness="1" Padding="2" Background="White">
                    <DatePicker x:Name="DpEnd" Language="tr-TR" Width="110" SelectedDateChanged="DpDate_SelectedDateChanged" BorderThickness="0" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Seçili Dönem Satış" FontSize="13" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtPeriodSales" Text="₺0,00" FontSize="26" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Seçili Dönem Ciro (Tahsil Edilen)" FontSize="13" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtPeriodRevenue" Text="₺0,00" FontSize="26" FontWeight="Bold" Foreground="#10B981" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Seçili Dönemde Oluşan Borç" FontSize="13" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtPeriodDebt" Text="₺0,00" FontSize="26" FontWeight="Bold" Foreground="#EF4444" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="⚠️ Kritik Stok Uyarıları" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="ListLowStock">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding StockQty}" HorizontalAlignment="Right" Foreground="#EF4444" FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="Son İşlemler" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="ListRecentSales">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{Binding CustomerName}" FontWeight="Medium" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding TotalPrice, StringFormat=C}" HorizontalAlignment="Right" Foreground="#10B981" FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="En Borçlu Müşteriler" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="ListDebtors">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding TotalDebt, StringFormat=C}" HorizontalAlignment="Right" Foreground="#EF4444" FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>