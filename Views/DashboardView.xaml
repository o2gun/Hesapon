<UserControl x:Class="ConstruxERP.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBg}"
             Loaded="UserControl_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">

            <!-- Header -->
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Gösterge Paneli" Style="{StaticResource PageTitle}"/>
                    <TextBlock x:Name="TxtDate" FontSize="13"
                               Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Satış"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnNewSale_Click" Height="38" Padding="18,0"/>
            </Grid>

            <!-- KPI Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="BUGÜNÜN SATIŞLARI" Style="{StaticResource SectionLabel}"/>
                        <TextBlock x:Name="TxtTodaySales" Text="₺0.00"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,6,0,0"/>
                        <TextBlock Text="↑ Nakit + Kredi" FontSize="12"
                                   Foreground="{StaticResource Green}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="AYLIK CİRO" Style="{StaticResource SectionLabel}"/>
                        <TextBlock x:Name="TxtMonthlySales" Text="₺0.00"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,6,0,0"/>
                        <TextBlock Text="↑ Bu ay" FontSize="12"
                                   Foreground="{StaticResource Green}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="BEKLEYEN BORÇ" Style="{StaticResource SectionLabel}"/>
                        <TextBlock x:Name="TxtPendingDebt" Text="₺0.00"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource Red}" Margin="0,6,0,0"/>
                        <TextBlock x:Name="TxtDebtors" Text="0 müşteri"
                                   FontSize="12" Foreground="{StaticResource Orange}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="AKTİF SİPARİŞLER" Style="{StaticResource SectionLabel}"/>
                        <TextBlock x:Name="TxtActiveOrders" Text="0"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,6,0,0"/>
                        <TextBlock Text="Bugünkü işlemler" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Middle Row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Low Stock -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <StackPanel>
                        <Border Padding="18,14" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="⚠ Düşük Stok Uyarıları"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <Border Style="{StaticResource RedBadge}" HorizontalAlignment="Right">
                                    <TextBlock x:Name="TxtLowStockCount"
                                               Text="0 ürün" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#DC2626"/>
                                </Border>
                            </Grid>
                        </Border>

                        <ItemsControl x:Name="LowStockList" Margin="16,8,16,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="#1E293B"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Category}" FontSize="11"
                                                           Foreground="{StaticResource TextMuted}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding StockDisplay}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#EF4444"/>
                                                <TextBlock Text="stok / min" FontSize="10"
                                                           Foreground="{StaticResource TextMuted}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#F1F5F9"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtNoLowStock"
                                   Text="✅ Tüm stok seviyeleri normal."
                                   FontSize="13" Foreground="{StaticResource Green}"
                                   Margin="18,0,18,14" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Recent Sales -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                    <StackPanel>
                        <Border Padding="18,14" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                            <TextBlock Text="Son İşlemler"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </Border>

                        <ItemsControl x:Name="RecentSalesList" Margin="0,0,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid Margin="18,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding CustomerName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#0F172A"/>
                                                <TextBlock Text="{Binding SaleDate}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMuted}"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding ProductName}"
                                                       FontSize="12" Foreground="#374151"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2" Text="{Binding TotalDisplay}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#0F172A" VerticalAlignment="Center"/>

                                            <Border Grid.Column="3"
                                                    Background="{Binding StatusBg}"
                                                    CornerRadius="12" Padding="7,3"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusFg}"/>
                                            </Border>
                                        </Grid>
                                        <Rectangle Height="1" Fill="#F1F5F9" Margin="18,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Debts -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <Border Padding="18,14" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                        <TextBlock Text="Müşteri Borçları"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </Border>

                    <ItemsControl x:Name="DebtList" Margin="18,8,18,14">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid Margin="0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#1E293B"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DebtDisplay}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="#EF4444"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="#F1F5F9"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtNoDebt"
                               Text="✅ Bekleyen müşteri borcu yok."
                               FontSize="13" Foreground="{StaticResource Green}"
                               Margin="18,0,18,14" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>